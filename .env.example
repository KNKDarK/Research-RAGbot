# RAG Chat Bot Configuration Template

# Server settings
PORT=8501
HOST=localhost

# Ollama Endpoint Configuration (only used when EMBED_PROVIDER=ollama or LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434

# Embedding Provider: "ollama" (default) or "huggingface"
#   ollama     → uses EMBED_MODEL via local Ollama server
#   huggingface → uses HF_EMBED_MODEL via sentence-transformers (no server needed)
# EMBED_PROVIDER=huggingface
# EMBED_MODEL=nomic-embed-text
# HF_EMBED_MODEL=all-MiniLM-L6-v2

# LLM Provider: "ollama" (default), "openai", or "groq"
#   ollama  → uses LLM_MODEL via local Ollama server
#   openai  → uses OPENAI_MODEL via OpenAI API (requires OPENAI_API_KEY)
#   groq    → uses GROQ_MODEL via Groq API (requires GROQ_API_KEY)
# LLM_PROVIDER=openai
# LLM_MODEL=phi4-mini
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_API_KEY=gsk_...
